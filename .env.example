# OpenClaw Voltek — Environment Variables
#
# Built on the open-source OpenClaw gateway (https://github.com/openclaw/openclaw).
# Maintained by Voltek — actively developed and receiving upstream OpenClaw updates.
# Support: openclaw@voltekit.com
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.openclaw/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.openclaw/.env, then openclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in openclaw.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~

# Optional: import missing keys from your login shell profile.
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Model provider credentials (set at least one)
# -----------------------------------------------------------------------------

# --- Anthropic Claude via OAuth (RECOMMENDED — no raw API key needed) ---
# 1. Install the Claude Code CLI:  npm install -g @anthropic-ai/claude-code
# 2. Run:  claude setup-token
#    A browser login opens; after authorising, a setup token is printed.
# 3. Register it with OpenClaw:  openclaw models auth setup-token
#    OR paste the token below:
# CLAUDE_CODE_OAUTH_TOKEN=...

# --- Anthropic API key (alternative — use if you prefer direct key auth) ---
# 1. Go to https://console.anthropic.com → API Keys → Create Key
# 2. Copy the sk-ant-... value and paste below.
# ANTHROPIC_API_KEY=sk-ant-...

# Other providers (set whichever you use):
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# OPENCLAW_LIVE_OPENAI_KEY=sk-...
# OPENCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# OPENCLAW_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Groq LPU inference
# GROQ_API_KEY=gsk-...

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# RAG / memory search embeddings (optional — overrides openclaw.json config)
# -----------------------------------------------------------------------------
# Provider: openai | gemini | voyage | mistral | ollama | local | auto
OPENCLAW_EMBEDDING_PROVIDER=openai
# Model: text-embedding-3-large | text-embedding-3-small | gemini-embedding-001 | etc.
OPENCLAW_EMBEDDING_MODEL=text-embedding-3-large

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...

# -----------------------------------------------------------------------------
# Mia task queue (optional — used by the heartbeat agent)
# -----------------------------------------------------------------------------
# Override the default Mia DB directory (~/.openclaw/mia).
# MIA_DB_DIR=~/.openclaw/mia

# Telegram chat ID for Mia notifications (briefings, error reports, etc.).
# USER_TELEGRAM_CHAT_ID=...

# Social platform tokens (used by social-monitor / social-sync tasks).
# TWITTER_BEARER_TOKEN=...
# INSTAGRAM_ACCESS_TOKEN=...
# LINKEDIN_ACCESS_TOKEN=...
# YOUTUBE_API_KEY=...

# Google Calendar integration.
# GOOGLE_CALENDAR_TOKEN=...
